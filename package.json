{
  "name": "@vectojs/brings-cli",
  "version": "0.1.0",
  "description": "Scriptable local-first Brings design-document CLI.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "brings": "./src/cli.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "test": "bun test",
    "format:check": "prettier --check .",
    "lint": "oxlint --deny-warnings src test",
    "verify": "bun run format:check && bun run lint && bun run test && bun run build"
  },
  "dependencies": {
    "@vectojs/brings-core": "0.13.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "oxlint": "^1.73.0",
    "prettier": "^3.9.5",
    "typescript": "^7.0.2"
  }
}
