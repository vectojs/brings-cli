{
  "name": "@vectojs/brings-cli",
  "version": "0.2.0",
  "description": "Scriptable local-first Brings design-document CLI.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vectojs/brings-cli.git"
  },
  "bugs": {
    "url": "https://github.com/vectojs/brings-cli/issues"
  },
  "homepage": "https://brings-website.vectojs.org/",
  "bin": {
    "brings": "./src/cli.ts"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc --noEmit",
    "test": "bun test",
    "format:check": "prettier --check .",
    "lint": "oxlint --deny-warnings src test",
    "verify": "bun run format:check && bun run lint && bun run test && bun run build && npm pack --dry-run",
    "changeset": "changeset",
    "changeset:version": "changeset version"
  },
  "dependencies": {
    "@vectojs/brings-core": "0.15.0"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@types/bun": "^1.3.0",
    "oxlint": "^1.73.0",
    "prettier": "^3.9.5",
    "typescript": "^7.0.2"
  }
}
